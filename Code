#include <iostream>
#include <fstream>
#include <string>
#include <vector>
#include <iomanip>
using namespace std;

class Student {
public:
    int id;
    string name;
    float marks;

    Student() : id(0), marks(0.0) {}
    Student(int i, string n, float m) : id(i), name(n), marks(m) {}

    void input() {
        cout << "\nEnter Student ID: ";
        cin >> id;
        cin.ignore();
        cout << "Enter Student Name: ";
        getline(cin, name);
        cout << "Enter Student Marks: ";
        cin >> marks;
        cin.ignore();

        if (marks < 0 || marks > 100) {
            cout << "Invalid marks! Please enter marks between 0-100.\n";
            marks = 0;
        }
    }

    void display() const {
        cout << left << setw(8) << id 
             << setw(25) << name 
             << setw(10) << fixed << setprecision(2) << marks << endl;
    }

    void displayHeader() const {
        cout << left << setw(8) << "ID" 
             << setw(25) << "Name" 
             << setw(10) << "Marks" << endl;
        cout << string(43, '-') << endl;
    }
};

void addStudent() {
    Student s;
    s.input();

    ofstream file("students.dat", ios::binary | ios::app);
    if (!file) {
        cout << "Error opening file!\n";
        return;
    }

    string temp = s.name;
    int nameLen = temp.length();
    
    file.write((char*)&s.id, sizeof(s.id));
    file.write((char*)&nameLen, sizeof(nameLen));
    file.write(temp.c_str(), nameLen);
    file.write((char*)&s.marks, sizeof(s.marks));
    
    file.close();
    cout << "\n✓ Student added successfully.\n";
}

void displayStudents() {
    ifstream file("students.dat", ios::binary);
    if (!file) {
        cout << "No records found or error opening file.\n";
        return;
    }

    int id, nameLen;
    float marks;
    cout << "\n=== Student Records ===\n";

    Student dummy;
    dummy.displayHeader();

    while (file.read((char*)&id, sizeof(id))) {
        file.read((char*)&nameLen, sizeof(nameLen));
        char* nameBuffer = new char[nameLen + 1];
        file.read(nameBuffer, nameLen);
        nameBuffer[nameLen] = '\0';
        string name(nameBuffer);
        file.read((char*)&marks, sizeof(marks));

        Student s(id, name, marks);
        s.display();

        delete[] nameBuffer;
    }

    file.close();
    cout << string(43, '-') << endl;
}

void searchStudent() {
    int searchId;
    cout << "\nEnter ID to search: ";
    cin >> searchId;
    cin.ignore();

    ifstream file("students.dat", ios::binary);
    if (!file) {
        cout << "No records found.\n";
        return;
    }

    int id, nameLen;
    float marks;
    bool found = false;

    while (file.read((char*)&id, sizeof(id))) {
        file.read((char*)&nameLen, sizeof(nameLen));
        char* nameBuffer = new char[nameLen + 1];
        file.read(nameBuffer, nameLen);
        nameBuffer[nameLen] = '\0';
        string name(nameBuffer);
        file.read((char*)&marks, sizeof(marks));

        if (id == searchId) {
            cout << "\n=== Student Found ===\n";
            Student s(id, name, marks);
            s.displayHeader();
            s.display();
            found = true;
            delete[] nameBuffer;
            break;
        }

        delete[] nameBuffer;
    }

    file.close();

    if (!found)
        cout << "Student with ID " << searchId << " not found.\n";
}

void updateStudent() {
    int searchId;
    cout << "\nEnter ID to update: ";
    cin >> searchId;
    cin.ignore();

    ifstream infile("students.dat", ios::binary);
    ofstream outfile("temp.dat", ios::binary);

    if (!infile || !outfile) {
        cout << "Error opening file!\n";
        return;
    }

    int id, nameLen;
    float marks;
    bool found = false;

    while (infile.read((char*)&id, sizeof(id))) {
        infile.read((char*)&nameLen, sizeof(nameLen));
        char* nameBuffer = new char[nameLen + 1];
        infile.read(nameBuffer, nameLen);
        nameBuffer[nameLen] = '\0';
        string name(nameBuffer);
        infile.read((char*)&marks, sizeof(marks));

        if (id == searchId && !found) {
            cout << "Current Details:\n";
            Student s(id, name, marks);
            s.displayHeader();
            s.display();

            cout << "\nEnter new details:\n";
            s.input();

            string temp = s.name;
            nameLen = temp.length();

            outfile.write((char*)&s.id, sizeof(s.id));
            outfile.write((char*)&nameLen, sizeof(nameLen));
            outfile.write(temp.c_str(), nameLen);
            outfile.write((char*)&s.marks, sizeof(s.marks));

            found = true;
            cout << "✓ Student updated successfully.\n";
        } else {
            string temp(nameBuffer);
            nameLen = temp.length();
            outfile.write((char*)&id, sizeof(id));
            outfile.write((char*)&nameLen, sizeof(nameLen));
            outfile.write(temp.c_str(), nameLen);
            outfile.write((char*)&marks, sizeof(marks));
        }

        delete[] nameBuffer;
    }

    infile.close();
    outfile.close();

    if (!found) {
        cout << "Student with ID " << searchId << " not found.\n";
        remove("temp.dat");
    } else {
        remove("students.dat");
        rename("temp.dat", "students.dat");
    }
}

void deleteStudent() {
    int searchId;
    cout << "\nEnter ID to delete: ";
    cin >> searchId;
    cin.ignore();

    ifstream infile("students.dat", ios::binary);
    ofstream outfile("temp.dat", ios::binary);

    if (!infile || !outfile) {
        cout << "Error opening file!\n";
        return;
    }

    int id, nameLen;
    float marks;
    bool found = false;

    while (infile.read((char*)&id, sizeof(id))) {
        infile.read((char*)&nameLen, sizeof(nameLen));
        char* nameBuffer = new char[nameLen + 1];
        infile.read(nameBuffer, nameLen);
        nameBuffer[nameLen] = '\0';
        string name(nameBuffer);
        infile.read((char*)&marks, sizeof(marks));

        if (id == searchId) {
            found = true;
            cout << "Deleted: ID " << id << ", Name: " << name << endl;
        } else {
            string temp(nameBuffer);
            nameLen = temp.length();
            outfile.write((char*)&id, sizeof(id));
            outfile.write((char*)&nameLen, sizeof(nameLen));
            outfile.write(temp.c_str(), nameLen);
            outfile.write((char*)&marks, sizeof(marks));
        }

        delete[] nameBuffer;
    }

    infile.close();
    outfile.close();

    if (!found) {
        cout << "Student with ID " << searchId << " not found.\n";
        remove("temp.dat");
    } else {
        remove("students.dat");
        rename("temp.dat", "students.dat");
        cout << "✓ Student deleted successfully.\n";
    }
}

int main() {
    int choice;

    do {
        cout << "\n====== Student Management System ======\n";
        cout << "1. Add Student\n";
        cout << "2. Display All Students\n";
        cout << "3. Search Student\n";
        cout << "4. Update Student\n";
        cout << "5. Delete Student\n";
        cout << "6. Exit\n";
        cout << "========================================\n";
        cout << "Enter your choice: ";
        cin >> choice;
        cin.ignore();

        switch(choice) {
            case 1: addStudent(); break;
            case 2: displayStudents(); break;
            case 3: searchStudent(); break;
            case 4: updateStudent(); break;
            case 5: deleteStudent(); break;
            case 6: 
                cout << "Thank you for using Student Management System!\n";
                break;
            default: 
                cout << "Invalid choice! Please try again.\n";
        }

    } while(choice != 6);

    return 0;
}
